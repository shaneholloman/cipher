    "@types/diff": "^7.0.2",
    "@types/express": "^5.0.3",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash-es": "^4.17.12",
    "@types/mdast": "^4.0.4",
    "@types/mocha": "^10",
    "@types/node": "^20",
    "@types/pdfkit": "^0.17.4",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.0",
    "@types/sinon": "^17.0.4",
    "@types/stopword": "^2.0.3",
    "@types/update-notifier": "^6.0.8",
    "@vitejs/plugin-react": "^5.2.0",
    "chai": "^4",
    "eslint": "^9",
    "eslint-config-oclif": "^6",
    "eslint-config-prettier": "^10",
    "eslint-import-resolver-typescript": "^4.4.4",
    "expect-type": "^1.2.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.1",
    "mocha": "10.8.2",
    "nock": "^14.0.10",
    "oclif": "^4",
    "pdfkit": "^0.17.2",
    "shx": "^0.3.3",
    "sinon": "^21.0.0",
    "tailwindcss": "^4.2.2",
    "ts-node": "^10",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vite": "^7.3.2",
    "vite-plugin-pwa": "^1.2.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "./.env.production",
    "./bin",
    "./dist",
    "./oclif.manifest.json"
  ],
  "homepage": "https://www.byterover.dev/",
  "license": "Elastic-2.0",
  "main": "dist/index.js",
  "type": "module",
  "oclif": {
    "bin": "brv",
    "dirname": "brv",
    "commands": "./dist/oclif/commands",
    "hooks": {
      "init": [
        "./dist/oclif/hooks/init/block-command-update-npm",
        "./dist/oclif/hooks/init/welcome",
        "./dist/oclif/hooks/init/update-notifier",
        "./dist/oclif/hooks/init/validate-brv-config"
      ],
      "command_not_found": "./dist/oclif/hooks/command_not_found/handle-invalid-commands",
      "error": "./dist/oclif/hooks/error/clean-errors",
      "postrun": "./dist/oclif/hooks/postrun/restart-after-update"
    },
    "plugins": [
      "@oclif/plugin-help",
      "@oclif/plugin-update"
    ],
    "topicSeparator": " ",
    "topics": {
      "hub": {
        "description": "Browse and manage skills & bundles registry",
        "subtopics": {
          "registry": {
            "description": "Manage private hub registries"
          }
        }
      },
      "space": {
        "description": "Manage ByteRover spaces"
      }
    },
    "update": {
      "s3": {
        "host": "https://storage.googleapis.com/brv-releases"
      },
      "autoupdate": {
        "debounce": 1
      },
      "node": {
        "version": "24.13.1"
      }
    }
  },
  "repository": "campfirein/byterover-cli",
  "scripts": {
    "build": "shx rm -rf dist && tsc -b && shx cp -r src/server/templates dist/server/templates && shx cp -r src/agent/resources dist/agent/resources && npm run build:ui",
    "build:ui": "vite build src/webui --mode package",
    "build:ui:submodule": "node scripts/prepare-ui-submodule-links.mjs && vite build src/webui --mode submodule",
    "dev": "node bin/kill-daemon.js && npm run build && ./bin/dev.js",
    "dev:kill": "node bin/kill-daemon.js",
    "dev:ui": "node scripts/prepare-ui-submodule-links.mjs && vite dev src/webui --mode submodule",
    "dev:ui:package": "vite dev src/webui --mode package",
    "lint": "eslint",
    "lint:fix": "npm run lint -- --fix",
    "postpack": "shx rm -f oclif.manifest.json",
    "prepack": "npm run build && BRV_ENV=production oclif manifest",
    "prepare": "husky",
    "test": "mocha --forbid-only \"test/**/*.test.ts\"",
    "typecheck": "tsc --noEmit && tsc --noEmit -p src/webui/tsconfig.json",
    "version": "git add README.md"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "npm run lint:fix"
    ]
  },
  "types": "dist/index.d.ts",
  "bundleDependencies": [
    "@campfirein/brv-transport-client",
    "@campfirein/byterover-packages",
    "react",
    "react-dom",
    "react-reconciler",
    "ink",
    "fullscreen-ink",
    "@inkjs/ui",
    "ink-spinner",
    "ink-text-input",
    "ink-scroll-list",
    "ink-scroll-view",
    "@tanstack/react-query",
    "react-router-dom",
    "zustand"
  ]
}
